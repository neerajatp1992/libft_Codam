#include <stdio.h>
#include "ft_printf.h"

int main(void)
{
    int count1, count2;

    // String
    count1 = ft_printf("ft_printf: Hello %s\n", "World");
    count2 = printf("printf   : Hello %s\n", "World");
    printf("Return values → ft: %d | original: %d\n\n", count1, count2);

    // Character
    count1 = ft_printf("ft_printf: %c\n", 'A');
    count2 = printf("printf   : %c\n", 'A');
    printf("Return values → ft: %d | original: %d\n\n", count1, count2);

    // Integer
    count1 = ft_printf("ft_printf: %d\n", -42);
    count2 = printf("printf   : %d\n", -42);
    printf("Return values → ft: %d | original: %d\n\n", count1, count2);

    // Unsigned
    count1 = ft_printf("ft_printf: %u\n", 42);
    count2 = printf("printf   : %u\n", 42);
    printf("Return values → ft: %d | original: %d\n\n", count1, count2);

    // Hex lowercase
    count1 = ft_printf("ft_printf: %x\n", 255);
    count2 = printf("printf   : %x\n", 255);
    printf("Return values → ft: %d | original: %d\n\n", count1, count2);

    // Hex uppercase
    count1 = ft_printf("ft_printf: %X\n", 255);
    count2 = printf("printf   : %X\n", 255);
    printf("Return values → ft: %d | original: %d\n\n", count1, count2);

    // Pointer
    count1 = ft_printf("ft_printf: %p\n", &count1);
    count2 = printf("printf   : %p\n", &count1);
    printf("Return values → ft: %d | original: %d\n\n", count1, count2);

    // Percent
    count1 = ft_printf("ft_printf: %%\n");
    count2 = printf("printf   : %%\n");
    printf("Return values → ft: %d | original: %d\n\n", count1, count2);

    // NULL string
    count1 = ft_printf("ft_printf: %s\n", NULL);
    count2 = printf("printf   : %s\n", NULL);
    printf("Return values → ft: %d | original: %d\n\n", count1, count2);

    return 0;
}
