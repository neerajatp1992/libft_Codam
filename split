#include <stdlib.h>

/* Count number of words */
static int	count_words(const char *s, char c)
{
	int	i;
	int	count;

	i = 0;
	count = 0;
	while (s[i])
	{
		if (s[i] != c && (i == 0 || s[i - 1] == c))
			count++;
		i++;
	}
	return (count);
}

/* Allocate and copy one word */
static char	*get_word(const char *s, int start, char c)
{
	int		len;
	char	*word;
	int		i;

	len = 0;
	while (s[start + len] && s[start + len] != c)
		len++;

	word = (char *)malloc(sizeof(char) * (len + 1));
	if (!word)
		return (NULL);

	i = 0;
	while (i < len)
	{
		word[i] = s[start + i];
		i++;
	}
	word[i] = '\0';
	return (word);
}

/* Free memory if error happens */
static void	free_all(char **arr, int index)
{
	while (index >= 0)
		free(arr[index--]);
	free(arr);
}

/* Main function */
char	**ft_split(char const *s, char c)
{
	char	**result;
	int		i;
	int		j;

	if (!s)
		return (NULL);

	result = (char **)malloc(sizeof(char *) * (count_words(s, c) + 1));
	if (!result)
		return (NULL);

	i = 0;
	j = 0;
	while (s[i])
	{
		if (s[i] != c)
		{
			result[j] = get_word(s, i, c);
			if (!result[j])
				return (free_all(result, j - 1), NULL);
			j++;
			while (s[i] && s[i] != c)
				i++;
		}
		else
			i++;
	}
	result[j] = NULL;
	return (result);
}
